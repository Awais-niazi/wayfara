# Copy to .env and fill in
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
# PostgreSQL (preferred). Falls back to SQLite if unset.
# DATABASE_URL=postgres://awais-faiz@localhost:5432/wayfara

# ─── Supabase (identity authority) ───────────────────────────────────────────
# From the Supabase dashboard → Project Settings → API / Auth.
# Django VERIFIES tokens with the JWT secret and provisions advisors with the
# service-role key. The anon key is NOT here — it belongs in the mobile app
# (mobile: set SUPABASE_URL + SUPABASE_ANON_KEY in that environment).
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_JWT_SECRET=<Project Settings → API → JWT Settings → JWT Secret>
SUPABASE_SERVICE_ROLE_KEY=<Project Settings → API → service_role secret>

# ─── Email (production; app mail like reminders) ─────────────────────────────
# Point Django at the same SMTP provider you set for Supabase Auth (Resend/SES).
# Dev leaves these unset and mail prints to the console.
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=<smtp password / api key>
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=Wayfara <hello@yourdomain>

